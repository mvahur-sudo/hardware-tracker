generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPERADMIN
  IT_ADMIN
  EMPLOYEE
}

enum UserLocale {
  en
  et
}

enum AssetStatus {
  IN_STOCK
  ASSIGNED
  IN_MAINTENANCE
  RETIRED
  LOST
  DISPOSED
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  POOR
  DAMAGED
}

enum AssetCategoryKey {
  LAPTOP
  MONITOR
  MOUSE
  KEYBOARD
  ACCESSORY
}

enum MaintenanceType {
  PREVENTIVE
  REPAIR
  INSPECTION
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELED
}

enum ImportFormat {
  CSV
  XLSX
}

enum ImportJobStatus {
  PREVIEWED
  COMPLETED
  FAILED
}

model User {
  id                String              @id @default(uuid())
  email             String              @unique
  passwordHash      String
  firstName         String
  lastName          String
  role              UserRole
  locale            UserLocale          @default(en)
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  assignedAssets    Asset[]             @relation("AssetCurrentAssignee")
  createdAssets     Asset[]             @relation("AssetCreatedBy")
  updatedAssets     Asset[]             @relation("AssetUpdatedBy")
  assignments       Assignment[]        @relation("AssignmentUser")
  assignedBy        Assignment[]        @relation("AssignmentAssignedBy")
  maintenance       MaintenanceRecord[]
  auditLogs         AuditLog[]
  importJobs        ImportJob[]

  @@index([role, isActive])
}

model AssetCategory {
  id        String           @id @default(uuid())
  key       AssetCategoryKey @unique
  nameEn    String
  nameEt    String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  assets    Asset[]
}

model Asset {
  id                String             @id @default(uuid())
  assetTag          String             @unique
  serialNumber      String?            @unique
  qrCodeValue       String             @unique
  categoryId        String
  brand             String
  model             String
  status            AssetStatus        @default(IN_STOCK)
  condition         AssetCondition     @default(GOOD)
  purchaseDate      DateTime?
  purchasePrice     Decimal?           @db.Decimal(12, 2)
  warrantyEndDate   DateTime?
  vendor            String?
  location          String?
  notes             String?
  currentAssigneeId String?
  createdById       String
  updatedById       String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  category          AssetCategory      @relation(fields: [categoryId], references: [id])
  currentAssignee   User?              @relation("AssetCurrentAssignee", fields: [currentAssigneeId], references: [id], onDelete: SetNull)
  createdBy         User               @relation("AssetCreatedBy", fields: [createdById], references: [id])
  updatedBy         User               @relation("AssetUpdatedBy", fields: [updatedById], references: [id])
  assignments       Assignment[]
  maintenance       MaintenanceRecord[]

  @@index([assetTag])
  @@index([status, deletedAt])
  @@index([categoryId, deletedAt])
  @@index([currentAssigneeId, deletedAt])
  @@index([warrantyEndDate])
}

model Assignment {
  id                          String          @id @default(uuid())
  assetId                     String
  userId                      String
  assignedById                String
  assignedAt                  DateTime        @default(now())
  expectedReturnAt            DateTime?
  returnedAt                  DateTime?
  returnCondition             AssetCondition?
  notes                       String?
  handoverConfirmedByEmployee Boolean         @default(false)
  createdAt                   DateTime        @default(now())
  updatedAt                   DateTime        @updatedAt
  asset                       Asset           @relation(fields: [assetId], references: [id])
  user                        User            @relation("AssignmentUser", fields: [userId], references: [id])
  assignedBy                  User            @relation("AssignmentAssignedBy", fields: [assignedById], references: [id])

  @@index([assetId, returnedAt])
  @@index([userId, returnedAt])
  @@index([assignedAt])
}

model MaintenanceRecord {
  id          String            @id @default(uuid())
  assetId     String
  type        MaintenanceType
  title       String
  description String
  vendor      String?
  cost        Decimal?          @db.Decimal(12, 2)
  startedAt   DateTime
  completedAt DateTime?
  status      MaintenanceStatus @default(OPEN)
  createdById String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  asset       Asset             @relation(fields: [assetId], references: [id])
  createdBy   User              @relation(fields: [createdById], references: [id])

  @@index([assetId, status])
  @@index([startedAt])
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?
  action      String
  entityType  String
  entityId    String
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  actorUser   User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
}

model ImportJob {
  id          String          @id @default(uuid())
  createdById String
  fileName    String
  format      ImportFormat
  status      ImportJobStatus
  summary     Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  createdBy   User            @relation(fields: [createdById], references: [id])

  @@index([status])
  @@index([createdAt])
}
